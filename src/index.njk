  if(!grid) return;

  const CTA = '<div class="reader-cta"><span><b>Fancy trying it for real?</b> Two free trial sessions — no card, no commitment.</span>'+
    '<a class="btn btn-red" href="https://docs.google.com/forms/d/e/1FAIpQLSccYPQznMxHNNxLVHNszs0NP05q1-0U9q8ShkbQRaJMfDzR1g/viewform" target="_blank" rel="noopener"><span>Register Now →</span></a></div>';

  const POSTS = [
{%- for post in collections.blog %}
    { tag: {{ post.data.tag | dump | safe }}, title: {{ post.data.title | dump | safe }}, teaser: {{ post.data.teaser | dump | safe }}, body: {{ post.templateContent | dump | safe }} }{% if not loop.last %},{% endif %}
{%- endfor %}
  ];

  grid.innerHTML = POSTS.map((p,i)=>
    '<button type="button" class="bl-card" data-i="'+i+'">'+
      '<div class="bl-tag">'+p.tag+'</div>'+
      '<h3>'+p.title+'</h3>'+
      '<p>'+p.teaser+'</p>'+
      '<span class="bl-more">Read the full article →</span>'+
    '</button>'
  ).join('');

  const reader=$('#reader'), body=$('#readerBody');
  function open(i){
    const p=POSTS[i]; if(!p) return;
    body.innerHTML='<div class="r-tag">'+p.tag+'</div><h2 class="r-title">'+p.title+'</h2>'+p.body+CTA;
    reader.classList.add('on'); reader.setAttribute('aria-hidden','false');
    document.body.classList.add('locked');
    reader.scrollTop=0; body.parentElement.scrollTop=0;
    Snd.beep(1000,.05);
  }
  function close(){
    reader.classList.remove('on'); reader.setAttribute('aria-hidden','true');
    document.body.classList.remove('locked');
  }
  grid.addEventListener('click', e=>{
    const c=e.target.closest('.bl-card'); if(c) open(parseInt(c.dataset.i,10));
  });
  $('#readerX').addEventListener('click', close);
  reader.addEventListener('click', e=>{ if(e.target===reader) close(); });
  addEventListener('keydown', e=>{ if(e.key==='Escape' && reader.classList.contains('on')) close(); });
})();

/* ============================================================
   GALLERY + LIGHTBOX — full 40-photo archive from WCBA
   ============================================================ */
(function(){
  const grid=$('#galGrid');
  if(!grid) return;

  // [url, category] — every real photo from the live gallery page
  const IMGS=[
{%- for g in gallery.images %}
    ["{{ g.image }}","{{ g.category }}"]{% if not loop.last %},{% endif %}
{%- endfor %}
  ];
  const PREVIEW = 8;                 // shown before "View Full Gallery"
  let filter = 'All', expanded = false;

  grid.innerHTML = IMGS.map((im,i)=>
    '<div class="gal-it" data-i="'+i+'" data-cat="'+im[1]+'">'+
      '<img src="'+im[0]+'" alt="'+im[1]+' at White Corner Boxing Academy, Bengaluru" loading="lazy">'+
      '<div class="gal-cat">'+im[1]+'</div>'+
    '</div>'
  ).join('');

  const items = $$('.gal-it', grid);
  const cats = ['All'].concat(IMGS.map(m=>m[1]).filter((v,i,a)=>a.indexOf(v)===i));
  const filterBar=$('#galFilter'), moreBtn=$('#galMore'), countEl=$('#galCount');

  filterBar.innerHTML = cats.map((c,i)=>
    '<button type="button" class="gal-chip'+(i===0?' on':'')+'" data-cat="'+c+'">'+c+'</button>'
  ).join('');

  // which real indexes are currently visible (drives lightbox next/prev)
  let visible = [];
  function apply(){
    visible = [];
    items.forEach((it,i)=>{
      const cat = IMGS[i][1];
      const inFilter = (filter==='All' || cat===filter);
      const show = expanded ? inFilter : (i < PREVIEW);
      it.classList.toggle('hide', !show);
      if(show) visible.push(i);
    });
    countEl.innerHTML = expanded
      ? 'Showing <b>'+visible.length+'</b> of '+IMGS.length+' photos'
      : 'Showing <b>'+PREVIEW+'</b> of '+IMGS.length+' photos';
  }
  apply();

  moreBtn.addEventListener('click', ()=>{
    expanded = true;
    filterBar.classList.add('on');
    moreBtn.parentElement.style.display='none';
    apply();
    Snd.beep(900,.06);
  });
  filterBar.addEventListener('click', e=>{
    const chip=e.target.closest('.gal-chip'); if(!chip) return;
    filter = chip.dataset.cat;
    $$('.gal-chip',filterBar).forEach(c=>c.classList.toggle('on', c===chip));
    apply();
  });

  /* lightbox — navigates the currently visible set */
  const lb=$('#lb'), lbImg=$('#lbImg');
  let pos=0;
  function open(i){
    pos=(i+visible.length)%visible.length;
    const im=IMGS[visible[pos]];
    lbImg.src=im[0]; lbImg.alt=im[1]+' — White Corner Boxing Academy';
    lb.classList.add('on'); document.body.classList.add('locked');
    Snd.beep(1000,.05);
  }
  function close(){ lb.classList.remove('on'); document.body.classList.remove('locked'); }
  grid.addEventListener('click', e=>{
    const it=e.target.closest('.gal-it'); if(!it) return;
    const realIdx=parseInt(it.dataset.i,10);
    const p=visible.indexOf(realIdx); if(p>=0) open(p);
  });
  $('#lbX').addEventListener('click', close);
  $('#lbPrev').addEventListener('click', e=>{ e.stopPropagation(); open(pos-1); });
  $('#lbNext').addEventListener('click', e=>{ e.stopPropagation(); open(pos+1); });
  lb.addEventListener('click', e=>{ if(e.target===lb) close(); });
  addEventListener('keydown', e=>{
    if(!lb.classList.contains('on')) return;
    if(e.key==='Escape') close();
    if(e.key==='ArrowLeft') open(pos-1);
    if(e.key==='ArrowRight') open(pos+1);
  });
})();

/* ============================================================
   THE TWO CORNERS — alternating video + full theme flip
   ============================================================ */
const Corner = (function(){
  const hero=$('#top'), layRed=$('#layRed'), layBlue=$('#layBlue'),
        frame=$('#vimeoFrame'), badge=$('#cornerBadge'), sub=$('#heroSub'),
        g1=$('#g1'), g2=$('#g2'), chips=$$('.cnr');
  if(!hero) return {go(){}};

  const DWELL = 14000;           // ms each corner holds the stage
  let cur='red', timer=null, alive=true, frameLoaded=false, busy=false;

  const COPY = {
    red:{
      l1:{{ site.hero.red.l1 | dump | safe }}, l2:{{ site.hero.red.l2 | dump | safe }},
      badge:{{ site.hero.red.badge | dump | safe }},
      sub:{{ site.hero.red.sub | dump | safe }}
    },
    blue:{
      l1:{{ site.hero.blue.l1 | dump | safe }}, l2:{{ site.hero.blue.l2 | dump | safe }},
      badge:{{ site.hero.blue.badge | dump | safe }},
      sub:{{ site.hero.blue.sub | dump | safe }}
    }
  };

  // load the Vimeo film only when it is first needed
  function loadFrame(){
    if(frameLoaded || !frame) return;
    frameLoaded=true;
    frame.src = frame.dataset.src;
  }

  // scramble one line of the headline into its new text
  const CH='ABCDEFGHIJKLMNOPQRSTUVWXYZ#%&/*+=';
  function scramble(el, next){
    if(RM){ el.textContent=next; el.dataset.t=next; return; }
    const from = el.textContent, len = Math.max(from.length, next.length);
    let f=0;
    const total = 16;
    clearInterval(el._sc);
    el._sc = setInterval(()=>{
      f++;
      let out='';
      for(let i=0;i<len;i++){
        const prog = (f - i*0.55) / 7;
        if(prog>=1) out += next[i]||'';
        else if(prog>0) out += CH[Math.floor(Math.random()*CH.length)];
        else out += from[i]||'';
      }
      el.textContent=out;
      if(f>total){ clearInterval(el._sc); el.textContent=next; el.dataset.t=next; }
    }, 26);
  }

  // whoosh + bell on the corner change
  function swoosh(){
    if(!Snd.ready()) return;
    const c=Snd.ctx, t=c.currentTime;
    const len=Math.floor(c.sampleRate*0.5);
    const buf=c.createBuffer(1,len,c.sampleRate), d=buf.getChannelData(0);
    for(let i=0;i<len;i++){ d[i]=(Math.random()*2-1)*Math.pow(1-i/len,1.6); }
    const src=c.createBufferSource(); src.buffer=buf;
    const bp=c.createBiquadFilter(); bp.type='bandpass'; bp.Q.value=1.1;
    bp.frequency.setValueAtTime(280,t);
    bp.frequency.exponentialRampToValueAtTime(3600,t+.34);
    const g=c.createGain();
    g.gain.setValueAtTime(.0001,t);
    g.gain.linearRampToValueAtTime(.3,t+.1);
    g.gain.exponentialRampToValueAtTime(.0001,t+.5);
    src.connect(bp); bp.connect(g); g.connect(Snd.master);
    src.start(t); src.stop(t+.52);
  }

  function go(next, manual){
    if(busy || next===cur) return;
    busy=true;
    if(next==='blue') loadFrame();

    // 1. glitch curtain
    hero.classList.add('switching');
    swoosh();
    if(manual) impact(false);

    // 2. flip theme + video mid-glitch, so the change lands inside the noise
    setTimeout(()=>{
      cur=next;
      document.body.dataset.corner=next;
      hero.dataset.corner=next;
      layRed.classList.toggle('on', next==='red');
      layBlue.classList.toggle('on', next==='blue');

      const c=COPY[next];
      scramble(g1, c.l1);
      scramble(g2, c.l2);
      badge.textContent=c.badge;
      sub.style.opacity='0';
      setTimeout(()=>{ sub.innerHTML=c.sub; sub.style.opacity=''; }, 220);

      chips.forEach(ch=>{
        const on = ch.dataset.go===next;
        ch.classList.toggle('on', on);
        // restart the dwell bar cleanly
        const bar=ch.querySelector('.cnr-bar');
        if(bar){ bar.style.animation='none'; void bar.offsetWidth; bar.style.animation=''; }
      });
      Snd.bell(1);
    }, 190);

    setTimeout(()=>{ hero.classList.remove('switching'); busy=false; }, 680);
    arm();
  }

  function arm(){
    clearTimeout(timer);
    if(!alive) return;
    timer=setTimeout(()=> go(cur==='red'?'blue':'red'), DWELL);
  }

  // only run the carousel while the hero is actually on screen
  const io=new IntersectionObserver(es=>{
    es.forEach(e=>{
      alive = e.isIntersecting;
      if(alive) arm(); else clearTimeout(timer);
    });
  },{threshold:.15});
  io.observe(hero);

  chips.forEach(ch=> ch.addEventListener('click', ()=> go(ch.dataset.go, true)));
  hero.style.setProperty('--dwell', DWELL+'ms');
  document.body.dataset.corner='red';
  sub.style.transition='opacity .22s ease';

  // preload the film shortly after entry so the first flip is instant
  setTimeout(loadFrame, 2600);
  arm();
  return {go};
})();

/* ============================================================
   VIDEO RESILIENCE — keep the reel alive
   ============================================================ */
(function(){
  $$('video').forEach(v=>{
    v.muted=true; v.playsInline=true;
    const kick=()=> v.play().catch(()=>{});
    v.addEventListener('loadeddata', kick);
    v.addEventListener('stalled', kick);
    v.addEventListener('pause', ()=>{ if(!document.hidden) kick(); });
    document.addEventListener('visibilitychange', ()=>{ if(!document.hidden) kick(); });
    kick();
  });
})();

})();
</script>

<!-- applies the owner's details from the EDIT AREA at the top of the page -->
<script>
(function(){
  var d = window.WCB_DETAILS || {};
  var phone = (d.phone||"").replace(/[^0-9]/g,"");
  // pretty display like "+91 95640 73380" from a raw "919564073380"
  function pretty(p){
    if(p.length===12 && p.indexOf("91")===0){
      return "+91 "+p.slice(2,7)+" "+p.slice(7);
    }
    return p ? "+"+p : "";
  }
  // 1. every WhatsApp link — keep any pre-filled ?text= message
  if(phone) document.querySelectorAll('a[href*="wa.me/"]').forEach(function(a){
    var q = a.getAttribute("href").split("?")[1];
    a.setAttribute("href","https://wa.me/"+phone+(q?"?"+q:""));
  });
  // 2. every Register-Now / Google Form link
  if(d.formUrl) document.querySelectorAll('a[href*="docs.google.com/forms"]').forEach(function(a){
    a.setAttribute("href", d.formUrl);
  });
  // 3. every email link
  if(d.email) document.querySelectorAll('a[href^="mailto:"]').forEach(function(a){
    a.setAttribute("href","mailto:"+d.email);
  });
  // 4. visible phone / email text
  if(phone) document.querySelectorAll('[data-wcb="phone"]').forEach(function(el){ el.textContent = pretty(phone); });
  if(d.email) document.querySelectorAll('[data-wcb="email"]').forEach(function(el){ el.textContent = d.email; });
})();
</script>
