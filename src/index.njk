<script>
(function(){
"use strict";
const $ = (s,c)=> (c||document).querySelector(s);
const $$ = (s,c)=> Array.from((c||document).querySelectorAll(s));
const clamp=(v,a,b)=>Math.min(b,Math.max(a,v));
const RM = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

/* ============================================================
   AUDIO — everything synthesized, zero external files
   ============================================================ */
const Snd = {
  ctx:null, on:true, master:null,
  init(){
    if(this.ctx) return;
    const AC = window.AudioContext||window.webkitAudioContext;
    if(!AC) return;
    this.ctx = new AC();
    this.master = this.ctx.createGain();
    this.master.gain.value = .5;
    this.master.connect(this.ctx.destination);
  },
  ready(){ this.init(); if(this.ctx && this.ctx.state==='suspended') this.ctx.resume(); return !!this.ctx && this.on; },
  // heavy-bag thud: filtered noise burst + low sine drop
  thud(power){
    if(!this.ready()) return;
    const c=this.ctx, t=c.currentTime, p=clamp(power||.5,.1,1);
    const len=Math.floor(c.sampleRate*0.22);
    const buf=c.createBuffer(1,len,c.sampleRate), d=buf.getChannelData(0);
    for(let i=0;i<len;i++){ d[i]=(Math.random()*2-1)*Math.pow(1-i/len,2.4); }
    const src=c.createBufferSource(); src.buffer=buf;
    const lp=c.createBiquadFilter(); lp.type='lowpass';
    lp.frequency.setValueAtTime(900+p*1400,t);
    lp.frequency.exponentialRampToValueAtTime(140,t+.2);
    const ng=c.createGain();
    ng.gain.setValueAtTime(.55*p+.15,t);
    ng.gain.exponentialRampToValueAtTime(.0001,t+.24);
    src.connect(lp); lp.connect(ng); ng.connect(this.master); src.start(t); src.stop(t+.26);
    // body
    const o=c.createOscillator(), og=c.createGain();
    o.type='sine';
    o.frequency.setValueAtTime(150+p*60,t);
    o.frequency.exponentialRampToValueAtTime(42,t+.17);
    og.gain.setValueAtTime(.6*p+.12,t);
    og.gain.exponentialRampToValueAtTime(.0001,t+.2);
    o.connect(og); og.connect(this.master); o.start(t); o.stop(t+.22);
  },
  // ring bell: inharmonic partials, long decay
  bell(times){
    if(!this.ready()) return;
    const n = times||1;
    for(let k=0;k<n;k++){
      const t=this.ctx.currentTime + k*.42;
      [1,2.76,5.4,8.9,11.2].forEach((mult,i)=>{
        const o=this.ctx.createOscillator(), g=this.ctx.createGain();
        o.type = i===0?'sine':'triangle';
        o.frequency.value = 620*mult * (1 + (Math.random()-.5)*.004);
        const amp = .34/Math.pow(i+1,1.35);
        g.gain.setValueAtTime(0,t);
        g.gain.linearRampToValueAtTime(amp,t+.004);
        g.gain.exponentialRampToValueAtTime(.0001, t + 1.9/(i*.55+1));
        o.connect(g); g.connect(this.master);
        o.start(t); o.stop(t+2.1);
      });
    }
  },
  beep(f,dur,type){
    if(!this.ready()) return;
    const c=this.ctx,t=c.currentTime;
    const o=c.createOscillator(), g=c.createGain();
    o.type=type||'square'; o.frequency.value=f||880;
    g.gain.setValueAtTime(.001,t);
    g.gain.linearRampToValueAtTime(.16,t+.008);
    g.gain.exponentialRampToValueAtTime(.0001,t+(dur||.09));
    o.connect(g); g.connect(this.master); o.start(t); o.stop(t+(dur||.09)+.02);
  }
};

const sndBtn = $('#sndBtn');
sndBtn.classList.add('on');
sndBtn.addEventListener('click', ()=>{
  Snd.on = !Snd.on;
  sndBtn.classList.toggle('on', Snd.on);
  if(Snd.on){ Snd.ready(); Snd.beep(1200,.07); }
});

/* ============================================================
   PRELOADER
   ============================================================ */
(function(){
  const pre=$('#pre'), fill=$('#preFill'), pct=$('#prePct'), enter=$('#preEnter');
  let p=0;
  const tick=setInterval(()=>{
    p += Math.random()*13 + 5;
    if(p>=100){ p=100; clearInterval(tick); enter.classList.add('on'); pct.textContent='READY'; }
    fill.style.width=p+'%';
    if(p<100) pct.textContent='LOADING '+Math.floor(p)+'%';
  },110);

  function go(){
    Snd.ready(); Snd.bell(3);
    pre.classList.add('gone');
    document.body.classList.remove('locked');
    setTimeout(()=>{ pre.remove(); fireGlitch(); }, 900);
    const v=$('#heroVid'); if(v) v.play().catch(()=>{});
  }
  enter.addEventListener('click', go);
  // safety: never trap the user behind the preloader
  setTimeout(()=>{ if(document.body.classList.contains('locked')) go(); }, 9000);
})();

function fireGlitch(){
  [$('#g1'),$('#g2')].forEach((el,i)=>{
    if(!el) return;
    setTimeout(()=>{
      el.classList.add('fire');
      setTimeout(()=>el.classList.remove('fire'), 700);
    }, i*140);
  });
}
setInterval(()=>{ if(!document.body.classList.contains('locked')) fireGlitch(); }, 7000);

/* ============================================================
   CURSOR
   ============================================================ */
(function(){
  const cur=$('#cur'), dot=$('#curDot');
  if(!cur) return;
  let cx=innerWidth/2, cy=innerHeight/2, tx=cx, ty=cy;
  addEventListener('mousemove', e=>{
    tx=e.clientX; ty=e.clientY;
    dot.style.transform='translate('+tx+'px,'+ty+'px)';
  }, {passive:true});
  (function loop(){
    cx += (tx-cx)*.18; cy += (ty-cy)*.18;
    cur.style.transform='translate('+cx+'px,'+cy+'px)';
    requestAnimationFrame(loop);
  })();
  const hot='a,button,.card,.gal-it,.bag,.pad,.v-card,.slot';
  document.addEventListener('mouseover', e=>{
    if(e.target.closest(hot)) document.body.classList.add('hot');
  });
  document.addEventListener('mouseout', e=>{
    if(e.target.closest(hot)) document.body.classList.remove('hot');
  });
})();

