/* ============================================================
   REVEAL + COUNTERS
   ============================================================ */
(function(){
  const io = new IntersectionObserver((es)=>{
    es.forEach(e=>{
      if(!e.isIntersecting) return;
      e.target.classList.add('in');
      const num = e.target.querySelector('[data-count]');
      if(num && !num.dataset.done){ num.dataset.done='1'; count(num); }
      io.unobserve(e.target);
    });
  }, {threshold:.16, rootMargin:'0px 0px -60px 0px'});
  $$('.rv').forEach((el,i)=>{ el.style.transitionDelay = (i%4)*70 + 'ms'; io.observe(el); });

  function count(el){
    const target = parseFloat(el.dataset.count)||0;
    const suffix = el.dataset.suffix||'';
    const dur=1400, t0=performance.now();
    (function step(t){
      const k = clamp((t-t0)/dur,0,1);
      const e = 1-Math.pow(1-k,3);
      el.innerHTML = Math.round(target*e) + (suffix?'<small>'+suffix+'</small>':'');
      if(k<1) requestAnimationFrame(step);
    })(t0);
  }
})();

/* ============================================================
   CARD SPOTLIGHT + TILT
   ============================================================ */
$$('.card').forEach(card=>{
  card.addEventListener('mousemove', e=>{
    const r=card.getBoundingClientRect();
    card.style.setProperty('--mx', (e.clientX-r.left)+'px');
    card.style.setProperty('--my', (e.clientY-r.top)+'px');
    if(RM) return;
    const rx = ((e.clientY-r.top)/r.height - .5) * -6;
    const ry = ((e.clientX-r.left)/r.width - .5) * 6;
    card.style.transform = 'translateY(-8px) perspective(900px) rotateX('+rx+'deg) rotateY('+ry+'deg)';
  });
  card.addEventListener('mouseleave', ()=>{ card.style.transform=''; });
});

/* ============================================================
   SCREEN IMPACT
   ============================================================ */
let shakeT=null;
function impact(strong){
  if(RM) return;
  const f=$('#flash');
  document.body.classList.remove('shake'); void document.body.offsetWidth;
  document.body.classList.add('shake');
  clearTimeout(shakeT);
  shakeT=setTimeout(()=>document.body.classList.remove('shake'),240);
  if(strong){ f.classList.remove('go'); void f.offsetWidth; f.classList.add('go'); }
}

/* ============================================================
   THE BAG — pendulum physics
   ============================================================ */
(function(){
  const stage=$('#stage'), pivot=$('#pivot'), bagEl=$('#bagEl');
  if(!stage||!pivot||!bagEl) return;

  const hPunch=$('#hPunch'), hCombo=$('#hCombo'), hPower=$('#hPower'),
        pwFill=$('#pwFill'), hRank=$('#hRank');

  let angle=0, vel=0;          // radians, rad/s
  let punches=0, combo=0, best=0, power=0, lastHit=0;
  let comboTimer=null;

  const WORDS=['JAB','CROSS','HOOK','UPPERCUT','BODY SHOT','1-2!','COMBO!','SLIP','RIP','THUD'];
  const RANKS=[
    [0,'Walk-In'],[6,'Rookie'],[14,'Prospect'],[26,'Contender'],
    [42,'Ranked'],[64,'Title Shot'],[90,'Champion'],[130,'Undisputed']
  ];

  function rank(n){
    let r=RANKS[0][1];
    for(const [th,name] of RANKS) if(n>=th) r=name;
    return r;
  }

  // physics loop
  let last=performance.now();
  function loop(now){
    const dt = Math.min((now-last)/1000, .05);
    last=now;
    // heavy-bag pendulum: long arm = slow swing, strong damping = settles fast, small amplitude
    const g=9.81, L=3.4;
    const acc = -(g/L)*Math.sin(angle) - vel*1.05;
    vel += acc*dt;
    angle += vel*dt;
    angle = clamp(angle, -0.34, 0.34);   // a loaded bag barely swings ~20°
    // a filled bag hardly deforms — just a whisper of squash on hard hits
    const sq = 1 - Math.min(Math.abs(vel)*0.006, .028);
    pivot.style.transform = 'translateX(-50%) rotate('+(angle*180/Math.PI).toFixed(3)+'deg) scaleY('+sq.toFixed(3)+')';
    requestAnimationFrame(loop);
  }
  requestAnimationFrame(loop);

  function fx(x,y,p){
    // ring
    const ring=document.createElement('div');
    ring.className='hitfx';
    ring.style.left=x+'px'; ring.style.top=y+'px';
    stage.appendChild(ring);
    setTimeout(()=>ring.remove(),600);

    // word
    const w=document.createElement('div');
    w.className='hitword';
    w.textContent = combo>0 && combo%10===0 ? 'COMBO ×'+combo+'!' : WORDS[Math.floor(Math.random()*WORDS.length)];
    w.style.left=x+'px'; w.style.top=(y-16)+'px';
    w.style.fontSize = (28 + p*22)+'px';
    stage.appendChild(w);
    setTimeout(()=>w.remove(),800);

    // sparks
    const n = 5 + Math.floor(p*8);
    for(let i=0;i<n;i++){
      const s=document.createElement('div');
      s.className='spark';
      s.style.left=x+'px'; s.style.top=y+'px';
      const a=Math.random()*Math.PI*2, d=26+Math.random()*70*p;
      s.style.background = Math.random()>.45 ? '#ffb800' : '#ff2b1f';
      s.animate([
        {transform:'translate(0,0) scale(1)', opacity:1},
        {transform:'translate('+Math.cos(a)*d+'px,'+(Math.sin(a)*d+34)+'px) scale(0)', opacity:0}
      ], {duration:480+Math.random()*320, easing:'cubic-bezier(.16,1,.3,1)'});
      stage.appendChild(s);
      setTimeout(()=>s.remove(),820);
    }
  }

  function hit(e){
    e.preventDefault();
    const now=performance.now();
    const rect=stage.getBoundingClientRect();
    const bRect=bagEl.getBoundingClientRect();
    const cx = (e.touches? e.touches[0].clientX : e.clientX);
    const cy = (e.touches? e.touches[0].clientY : e.clientY);
    const x = cx - rect.left, y = cy - rect.top;

    // power from rhythm: fast, rhythmic punches hit harder
    const gap = now - lastHit;
    lastHit = now;
    const rhythm = clamp(1 - Math.abs(gap-260)/900, .25, 1);
    // hit low on the bag = body shot = more power
    const depth = clamp((cy - bRect.top)/Math.max(bRect.height,1), 0, 1);
    const p = clamp(rhythm*.65 + depth*.35, .15, 1);

    // swing direction from which side you hit — small base impulse, power-scaled (heavy bag)
    const side = (cx < bRect.left + bRect.width/2) ? 1 : -1;
    vel += side * (0.08 + p*0.46);

    punches++;
    combo++;
    if(combo>best) best=combo;
    power = Math.round(p*100);

    hPunch.textContent = punches;
    hCombo.textContent = '×'+combo;
    hCombo.classList.remove('combo-flash'); void hCombo.offsetWidth; hCombo.classList.add('combo-flash');
    hPower.innerHTML = Math.round(220 + p*680) + '<span style="font-size:.4em"> PSI</span>';
    pwFill.style.width = power+'%';
    hRank.textContent = rank(punches);

    fx(x,y,p);
    Snd.thud(p);
    if(p>.75 || combo%10===0) impact(combo%10===0);
    if(combo%10===0) Snd.bell(1);

    clearTimeout(comboTimer);
    comboTimer=setTimeout(()=>{
      combo=0; hCombo.textContent='×0'; pwFill.style.width='0%';
    }, 1100);
  }

  bagEl.addEventListener('mousedown', hit);
  bagEl.addEventListener('touchstart', hit, {passive:false});
  // idle sway so it feels alive (gentle — it's a loaded bag)
  setInterval(()=>{ if(performance.now()-lastHit > 4000) vel += (Math.random()-.5)*.035; }, 2600);
})();

/* ============================================================
   THE MAP — three branches pinned on a dark Bengaluru
   ============================================================ */
(function(){
  const el=$('#wcbMap'); if(!el) return;
  const fallback=$('#mapFallback'), track=$('#bmTrack');

  const BRANCHES=[
    {name:'HSR Layout',   sub:'Main Branch',   lat:12.9070833, lng:77.6351607,
     addr:'35, 36 Dolphin Towers, Mangammanapalya Main Rd, Yellankunte, 560068',
     q:'White Corner Boxing Academy, HSR Layout, Bengaluru 560068'},
    {name:'Koramangala',  sub:'Third Branch',  lat:12.936447, lng:77.619097,
     addr:'First Floor, No 11, 4th C Cross, KHB Colony, 5th Block, Koramangala Industrial Layout, 560095 (above Uncle Peter\'s Pancakes)',
     q:'White Corner Boxing Academy, Koramangala, Bengaluru 560095'},
    {name:'Indiranagar',  sub:'Now Open',      lat:12.9793420, lng:77.6391534,
     addr:'2nd Floor, 152, 2nd Main Rd, Stage 1, Indiranagar, 560038',
     q:'White Corner Boxing Academy, Indiranagar, Bengaluru 560038'}
  ];
  // directions search by the branch NAME (Google resolves the real listing) — never raw coordinates
  const gmaps = b => 'https://www.google.com/maps/search/?api=1&query='+encodeURIComponent(b.q || b.name);

  // static row of the three branch names — A ‧ B ‧ C (dots only between)
  if(track){
    track.innerHTML = BRANCHES.map((b,i)=>
      '<button type="button" class="bm-item" data-i="'+i+'">'+b.name+'</button>'
    ).join('<span class="bm-dot">‧</span>');
  }
  const items = track ? $$('.bm-item', track) : [];

  function boot(){
    if(typeof L==='undefined'){
      if(fallback) fallback.classList.add('on');
      // no live map → a name click just opens directions
      items.forEach(it=> it.addEventListener('click', ()=> window.open(gmaps(BRANCHES[+it.dataset.i]),'_blank','noopener')));
      return;
    }

    const map = L.map(el,{scrollWheelZoom:false, attributionControl:true})
      .setView([12.945,77.628], 12);

    L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png',{
      subdomains:'abcd', maxZoom:19,
      attribution:'&copy; OpenStreetMap &copy; CARTO'
    }).addTo(map);

    // red "White Corner triangle" connecting the branches
    L.polyline(BRANCHES.map(b=>[b.lat,b.lng]).concat([[BRANCHES[0].lat,BRANCHES[0].lng]]),
      {color:'#e10600', weight:2, opacity:.55, dashArray:'6 8'}).addTo(map);

    const markers=[];
    BRANCHES.forEach((b,i)=>{
      const icon = L.divIcon({
        className:'', iconSize:[46,46], iconAnchor:[23,23],
        html:'<div class="pin"><span class="pin-ring"></span><span class="pin-core">🥊</span>'+
             '<span class="pin-tag">'+b.name+'</span></div>'
      });
      const m = L.marker([b.lat,b.lng],{icon}).addTo(map);
      m.bindPopup(
        '<div class="pop"><div class="pop-name">'+b.name+'</div>'+
        '<div class="pop-sub">'+b.sub+'</div>'+
        '<div class="pop-addr">'+b.addr+'</div>'+
        '<a class="pop-go" target="_blank" rel="noopener" href="'+gmaps(b)+'">Get Directions →</a></div>',
        {className:'wcb-pop'}
      );
      markers.push(m);
    });

    // frame all three
    map.fitBounds(L.latLngBounds(BRANCHES.map(b=>[b.lat,b.lng])).pad(0.42), {maxZoom:13});

    // click a sliding branch name → scroll to the map, fly there & open its pin
    // (all the details — address + directions — live in that popup)
    items.forEach(it=> it.addEventListener('click', ()=>{
      const i=+it.dataset.i;
      el.scrollIntoView({behavior:'smooth', block:'center'});
      map.flyTo([BRANCHES[i].lat,BRANCHES[i].lng], 15, {duration:.9});
      setTimeout(()=> markers[i].openPopup(), 300);
      Snd.beep(1000,.05);
    }));

    // enable wheel-zoom only after a click, so the page still scrolls past the map
    map.on('focus', ()=> map.scrollWheelZoom.enable());
    map.on('blur',  ()=> map.scrollWheelZoom.disable());
    // Leaflet sometimes needs a nudge once its container is laid out
    setTimeout(()=> map.invalidateSize(), 300);
  }

  // Leaflet is loaded with `defer`; wait for window load if it isn't ready yet
  if(typeof L!=='undefined') boot();
  else window.addEventListener('load', boot);
})();

